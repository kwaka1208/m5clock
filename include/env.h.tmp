#define ENV_SSID "your-ssid"
#define ENV_PASS "your-password"


#ifndef ENV_H
#define ENV_H

struct WifiConfig {
  const char *ssid;
  const char *password;
};

// Wi-Fi APリスト定数
const WifiConfig wifiConfigs[] = {
    {"your-ssid1", "your-password1"},
    {"your-ssid2", "your-password2"}
};

// APリストの要素数を計算
const int wifiConfigCount = sizeof(wifiConfigs) / sizeof(wifiConfigs[0]);

#endif